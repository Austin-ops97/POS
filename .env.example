# ─── Required for production ─────────────────────────────────────────────────
# Copy to .env and fill in real values.

# PostgreSQL — Neon requires two URLs:
#
# DATABASE_URL: pooled connection used by the running Next.js application.
# DIRECT_URL: non-pooled connection used by Prisma migrations / schema CLI.
# Username, password, database name, and query params should match.
# The DIRECT_URL hostname must NOT contain "-pooler".
#
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require"

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Local-only single-user auth when Clerk keys are unset. Never enable in production.
# ALLOW_DEV_AUTH_BYPASS=true

# Stripe (https://dashboard.stripe.com) — merchant payments via Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: only needed if you prefer a build-time client env var
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Configure webhook endpoint: /api/webhooks/stripe
# Connect/payment events: payment_intent.*, charge.refunded, account.updated
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: error monitoring
# SENTRY_DSN=https://...@sentry.io/...

# Optional: multi-instance rate limiting (Upstash Redis REST)
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Optional: signing secret for register cashier cookies (falls back to CLERK_SECRET_KEY)
# REGISTER_CASHIER_SECRET=long-random-string

# Optional: barcode / external product lookup
PRODUCT_LOOKUP_ENABLED=true
PRODUCT_LOOKUP_USER_AGENT="NexaPOS/0.1.0 (support@your-domain.com)"
PRODUCT_LOOKUP_CACHE_DAYS=30

# Optional: expense receipt blob storage path (defaults to .data/receipts)
# RECEIPT_STORAGE_PATH=/var/data/nexapos/receipts

# Transactional email for receipts (https://resend.com)
RESEND_API_KEY=re_...
RECEIPTS_FROM_EMAIL="NexaPOS <receipts@yourdomain.com>"
RECEIPTS_REPLY_TO_EMAIL=support@yourdomain.com
