# ─── Required for production ─────────────────────────────────────────────────
# Copy to .env and fill in real values.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/nexapos?schema=public"

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: only needed if you prefer a build-time client env var
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Configure webhook endpoint: /api/webhooks/stripe
# Billing events: checkout.session.completed, customer.subscription.*, invoice.payment_*
# Connect events: payment_intent.*, charge.refunded, account.updated
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Stripe Billing price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MULTI=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
