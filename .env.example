# ─── Required for production ─────────────────────────────────────────────────
# Copy to .env and fill in real values. Set NEXT_PUBLIC_DEMO_MODE=false for production.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/nexapos?schema=public"

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Stripe Billing price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MULTI=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to true to run without Clerk, Stripe, or PostgreSQL (Vercel previews, UI demos).
# Production: set to false and provide all keys above.
NEXT_PUBLIC_DEMO_MODE=false
