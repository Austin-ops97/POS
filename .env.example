# ─── Required for production ─────────────────────────────────────────────────
# Copy to .env and fill in real values.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/nexapos?schema=public"

# Clerk Authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (https://dashboard.stripe.com) — merchant payments via Connect
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: only needed if you prefer a build-time client env var
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Configure webhook endpoint: /api/webhooks/stripe
# Connect/payment events: payment_intent.*, charge.refunded, account.updated
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: error monitoring (Sentry-compatible hook in src/lib/monitoring.ts)
# SENTRY_DSN=https://...@sentry.io/...

# Transactional email for receipts (https://resend.com)
RESEND_API_KEY=re_...
RECEIPTS_FROM_EMAIL="NexaPOS <receipts@yourdomain.com>"
RECEIPTS_REPLY_TO_EMAIL=support@yourdomain.com
