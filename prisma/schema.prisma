generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BusinessType {
  RETAIL
  SERVICE
  RENTAL
  RESTAURANT
  HYBRID
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum ProductType {
  PHYSICAL
  SERVICE
  RENTAL
  DIGITAL
  CUSTOM
}

enum OrderStatus {
  DRAFT
  HELD
  PENDING_PAYMENT
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELED
  FAILED
}

enum PaymentMethod {
  CARD
  CASH
  GIFT_CARD
  STORE_CREDIT
  MANUAL
  SPLIT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REQUIRES_ACTION
}

enum RefundReason {
  CUSTOMER_RETURN
  DAMAGED_ITEM
  WRONG_ITEM
  DUPLICATE_CHARGE
  CUSTOMER_SATISFACTION
  OTHER
}

enum InventoryMovementType {
  SALE
  REFUND
  MANUAL_ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGED
  LOST
  RECEIVED
  RETURN_TO_STOCK
}

enum InventoryScanMode {
  RECEIVE
  CYCLE_COUNT
  DAMAGED
  LOST
}

enum InventoryScanSessionStatus {
  OPEN
  APPLIED
  CANCELLED
}

enum StripeAccountStatus {
  NOT_CONNECTED
  PENDING
  CONNECTED
  RESTRICTED
  READY
}

enum ReaderStatus {
  ONLINE
  OFFLINE
  BUSY
  NEEDS_UPDATE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum RegisterSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  PAID_IN
  PAID_OUT
  OPENING
  CLOSING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  REFUND
  VOID
  DISCOUNT
  INVENTORY_ADJUSTMENT
  SETTINGS_CHANGE
  EMPLOYEE_CHANGE
  LOGIN
  PAYMENT
  WORKFORCE_CHANGE
  TIME_ENTRY_ADJUSTMENT
  TIME_OFF_REVIEW
  PAYROLL_BONUS
  EXPENSE_CREATE
  EXPENSE_UPDATE
  EXPENSE_SUBMIT
  EXPENSE_APPROVE
  EXPENSE_REJECT
  EXPENSE_REIMBURSE
  EXPENSE_FLAG
  EXPENSE_COMMENT
  COMPANY_CARD_CHANGE
  EXPENSE_BUDGET_CHANGE
  EXPENSE_CATEGORY_CHANGE
}

enum PayPeriodType {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
}

enum ShiftStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TimeEntrySource {
  PIN_KIOSK
  MANUAL
}

enum TimeEntryStatus {
  ACTIVE
  COMPLETED
  ADJUSTED
}

enum TimeOffType {
  PTO
  SICK
  UNPAID
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  SEASONAL
  TEMPORARY
  CONTRACTOR
}

enum PayType {
  HOURLY
  SALARY
}

enum DisplayNameStrategy {
  LEGAL
  PREFERRED
  CUSTOM
}

enum PtoAccrualPolicy {
  ANNUAL_GRANT
  NONE
}

enum PtoLedgerType {
  ACCRUAL
  USAGE
  ADJUSTMENT
  CARRYOVER
  REVERSAL
}

// ─── Core Multi-Tenant ───────────────────────────────────────────────────────

model Business {
  id           String       @id @default(cuid())
  name         String
  legalName    String?
  type         BusinessType @default(RETAIL)
  phone        String?
  email        String?
  website      String?
  logoUrl      String?
  primaryColor String       @default("#1e3a5f")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  locations                 Location[]
  employees                 EmployeeProfile[]
  products                  Product[]
  productBarcodes           ProductBarcode[]
  categories                Category[]
  customers                 Customer[]
  orders                    Order[]
  payments                  Payment[]
  refunds                   Refund[]
  receipts                  Receipt[]
  inventoryMovements        InventoryMovement[]
  terminalReaders           TerminalReader[]
  modifierGroups            ModifierGroup[]
  discounts                 Discount[]
  taxRates                  TaxRate[]
  inventoryItems            InventoryItem[]
  inventoryScanSessions     InventoryScanSession[]
  stripeAccount             StripeAccount?
  settings                  BusinessSetting?
  moduleSettings            ModuleSetting[]
  auditLogs                 AuditLog[]
  registerSessions          RegisterSession[]
  workforceSettings         WorkforceSettings?
  shifts                    Shift[]
  timeEntries               TimeEntry[]
  timeOffRequests           TimeOffRequest[]
  payrollBonuses            PayrollBonus[]
  ptoLedgerEntries          PtoLedgerEntry[]
  barcodeMigrationConflicts BarcodeMigrationConflict[]
  expenseCategories         ExpenseCategory[]
  expenseVendors            ExpenseVendor[]
  companyCards              CompanyCard[]
  expenses                  Expense[]
  expenseBudgets            ExpenseBudget[]
  expenseNotifications      ExpenseNotification[]
  expenseAuditEvents        ExpenseAuditEvent[]
  companyCardTransactions   CompanyCardTransaction[]
  expenseSavedFilters       ExpenseSavedFilter[]
  expenseSettings           ExpenseSettings?
  expenseTags               ExpenseTag[]

  @@index([createdAt])
}

model Location {
  id         String    @id @default(cuid())
  businessId String
  name       String
  street     String?
  city       String?
  state      String?
  zip        String?
  country    String    @default("US")
  timezone   String    @default("America/New_York")
  taxRegion  String?
  isActive   Boolean   @default(true)
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryItems        InventoryItem[]
  inventoryScanSessions InventoryScanSession[]
  orders                Order[]
  taxRates              TaxRate[]
  terminalReaders       TerminalReader[]
  registerSessions      RegisterSession[]
  employeeLocations     EmployeeLocation[]
  defaultEmployees      EmployeeProfile[]      @relation("EmployeeDefaultLocation")
  shifts                Shift[]
  timeEntries           TimeEntry[]
  expenses              Expense[]

  @@index([businessId])
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees EmployeeProfile[]

  @@index([email])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  employees   EmployeeProfile[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model EmployeeProfile {
  id                  String              @id @default(cuid())
  businessId          String
  userId              String?
  roleId              String
  name                String
  email               String
  phone               String?
  pinHash             String?
  hourlyWage          Decimal?            @db.Decimal(10, 2)
  ptoBalanceHours     Decimal             @default(0) @db.Decimal(8, 2)
  ptoAnnualHours      Decimal             @default(0) @db.Decimal(8, 2)
  sickBalanceHours    Decimal             @default(0) @db.Decimal(8, 2)
  ptoCarryoverLimit   Decimal?            @db.Decimal(8, 2)
  ptoAccrualPolicy    PtoAccrualPolicy    @default(ANNUAL_GRANT)
  status              EmployeeStatus      @default(ACTIVE)
  legalFirstName      String?
  legalMiddleName     String?
  legalLastName       String?
  preferredName       String?
  displayNameStrategy DisplayNameStrategy @default(LEGAL)
  dateOfBirth         DateTime?           @db.Date
  personalEmail       String?
  workEmail           String?
  mobilePhone         String?
  secondaryPhone      String?
  profilePhotoUrl     String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  stateProvince       String?
  postalCode          String?
  country             String?             @default("US")
  employeeNumber      String?
  jobTitle            String?
  department          String?
  employmentType      EmploymentType?
  hireDate            DateTime?           @db.Date
  startDate           DateTime?           @db.Date
  terminationDate     DateTime?           @db.Date
  terminationReason   String?
  managerId           String?
  defaultLocationId   String?
  employmentNotes     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  business              Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                  User?                      @relation(fields: [userId], references: [id])
  role                  Role                       @relation(fields: [roleId], references: [id])
  manager               EmployeeProfile?           @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports         EmployeeProfile[]          @relation("EmployeeManager")
  defaultLocation       Location?                  @relation("EmployeeDefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)
  locations             EmployeeLocation[]
  emergencyContacts     EmployeeEmergencyContact[]
  compensationHistory   EmployeeCompensation[]
  compensationCreated   EmployeeCompensation[]     @relation("CompensationCreatedBy")
  ptoLedgerEntries      PtoLedgerEntry[]
  ptoAdjustmentsMade    PtoLedgerEntry[]           @relation("PtoAdjustedBy")
  orders                Order[]
  refunds               Refund[]
  registerSessions      RegisterSession[]
  auditLogs             AuditLog[]
  shifts                Shift[]
  shiftsCreated         Shift[]                    @relation("ShiftCreatedBy")
  timeEntries           TimeEntry[]
  timeEntriesAdjusted   TimeEntry[]                @relation("TimeEntryAdjustedBy")
  timeOffRequests       TimeOffRequest[]
  timeOffReviews        TimeOffRequest[]           @relation("TimeOffReviewedBy")
  payrollBonuses        PayrollBonus[]
  payrollBonusesCreated PayrollBonus[]             @relation("PayrollBonusCreatedBy")
  inventoryScanSessions InventoryScanSession[]
  assignedCompanyCards  CompanyCard[]              @relation("CompanyCardAssignee")
  companyCardsCreated   CompanyCard[]              @relation("CompanyCardCreatedBy")
  expenses              Expense[]                  @relation("ExpenseEmployee")
  expensesSubmitted     Expense[]                  @relation("ExpenseSubmittedBy")
  expenseApprovals      ExpenseApprovalEvent[]
  expenseComments       ExpenseComment[]
  expenseFlagsRaised    ExpenseFlag[]
  expenseNotifications  ExpenseNotification[]
  expenseAuditEvents    ExpenseAuditEvent[]
  expenseSavedFilters   ExpenseSavedFilter[]
  cardTransactions      CompanyCardTransaction[]

  @@unique([businessId, employeeNumber])
  @@index([businessId])
  @@index([email])
  @@index([businessId, status])
  @@index([managerId])
}

model EmployeeEmergencyContact {
  id             String   @id @default(cuid())
  employeeId     String
  name           String
  relationship   String
  primaryPhone   String
  alternatePhone String?
  email          String?
  isPrimary      Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeCompensation {
  id                 String    @id @default(cuid())
  employeeId         String
  payType            PayType
  hourlyRate         Decimal?  @db.Decimal(10, 2)
  annualSalary       Decimal?  @db.Decimal(12, 2)
  overtimeEligible   Boolean   @default(true)
  overtimeMultiplier Decimal   @default(1.5) @db.Decimal(4, 2)
  effectiveFrom      DateTime  @db.Date
  effectiveTo        DateTime? @db.Date
  notes              String?
  createdById        String?
  createdAt          DateTime  @default(now())

  employee  EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy EmployeeProfile? @relation("CompensationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([employeeId, effectiveFrom])
}

model PtoLedgerEntry {
  id           String        @id @default(cuid())
  businessId   String
  employeeId   String
  type         PtoLedgerType
  hours        Decimal       @db.Decimal(8, 2)
  balanceAfter Decimal       @db.Decimal(8, 2)
  reason       String?
  referenceId  String?
  adjustedById String?
  createdAt    DateTime      @default(now())

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  adjustedBy EmployeeProfile? @relation("PtoAdjustedBy", fields: [adjustedById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([employeeId])
  @@index([createdAt])
}

model EmployeeLocation {
  id         String @id @default(cuid())
  employeeId String
  locationId String

  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, locationId])
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([businessId])
}

model Product {
  id             String      @id @default(cuid())
  businessId     String
  categoryId     String?
  name           String
  description    String?
  sku            String?
  barcode        String?
  brand          String?
  supplier       String?
  imageUrl       String?
  price          Decimal     @db.Decimal(10, 2)
  cost           Decimal?    @db.Decimal(10, 2)
  type           ProductType @default(PHYSICAL)
  taxable        Boolean     @default(true)
  taxCategory    String?
  trackInventory Boolean     @default(true)
  isActive       Boolean     @default(true)
  isFavorite     Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  business       Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category       Category?              @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  barcodes       ProductBarcode[]
  modifierGroups ProductModifierGroup[]
  inventoryItems InventoryItem[]
  orderItems     OrderItem[]

  @@index([businessId])
  @@index([businessId, deletedAt])
  @@index([sku])
  @@index([barcode])
  @@index([createdAt])
  @@unique([businessId, sku])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  sku        String?
  barcode    String?
  price      Decimal? @db.Decimal(10, 2)
  attributes Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes   ProductBarcode[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@index([barcode])
}

/// Exact barcode assignments. Uniqueness is per-business on normalizedValue.
model ProductBarcode {
  id              String   @id @default(cuid())
  businessId      String
  productId       String
  variantId       String?
  rawValue        String
  normalizedValue String
  format          String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([businessId, normalizedValue])
  @@index([productId])
  @@index([variantId])
  @@index([businessId])
}

/// Public external catalog cache only — never merchant price/cost/stock.
model ExternalProductCache {
  id                String    @id @default(cuid())
  normalizedBarcode String    @unique
  source            String
  productType       String?
  name              String?
  brand             String?
  description       String?
  packageSize       String?
  imageUrl          String?
  manufacturer      String?
  categoryText      String?
  rawPayload        Json?
  confidence        Float?
  isNegative        Boolean   @default(false)
  fetchedAt         DateTime  @default(now())
  expiresAt         DateTime
  lastHitAt         DateTime?
  lookupCount       Int       @default(0)

  @@index([expiresAt])
  @@index([source])
}

/// Duplicate barcodes discovered during ProductBarcode backfill (ops report).
model BarcodeMigrationConflict {
  id              String   @id @default(cuid())
  businessId      String
  normalizedValue String
  rawValues       String[]
  productIds      String[]
  variantIds      String[]
  note            String?
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([normalizedValue])
}

model InventoryScanSession {
  id             String                     @id @default(cuid())
  businessId     String
  locationId     String
  employeeId     String
  mode           InventoryScanMode
  status         InventoryScanSessionStatus @default(OPEN)
  idempotencyKey String?                    @unique
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  appliedAt      DateTime?

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  employee EmployeeProfile     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  lines    InventoryScanLine[]

  @@index([businessId])
  @@index([locationId])
  @@index([employeeId])
  @@index([status])
}

model InventoryScanLine {
  id              String  @id @default(cuid())
  sessionId       String
  productId       String
  variantId       String?
  inventoryItemId String
  normalizedCode  String
  expectedQty     Int
  scannedQty      Int     @default(0)
  proposedDelta   Int

  session InventoryScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, inventoryItemId])
  @@index([sessionId])
  @@index([productId])
}

model ModifierGroup {
  id         String   @id @default(cuid())
  businessId String
  name       String
  required   Boolean  @default(false)
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  options  ModifierOption[]
  products ProductModifierGroup[]
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model ModifierOption {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
}

model ProductModifierGroup {
  id              String @id @default(cuid())
  productId       String
  modifierGroupId String

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model InventoryItem {
  id               String   @id @default(cuid())
  businessId       String
  locationId       String
  productId        String
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  reorderPoint     Int      @default(5)
  costPerUnit      Decimal? @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business  Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location  Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@unique([locationId, productId])
  @@index([businessId])
  @@index([locationId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  businessId      String
  inventoryItemId String
  type            InventoryMovementType
  quantity        Int
  previousQty     Int
  newQty          Int
  reason          String?
  referenceId     String?
  employeeId      String?
  createdAt       DateTime              @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([inventoryItemId])
  @@index([createdAt])
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id               String    @id @default(cuid())
  businessId       String
  firstName        String
  lastName         String?
  email            String?
  phone            String?
  address          String?
  notes            String?
  tags             String[]
  birthday         DateTime?
  marketingOptIn   Boolean   @default(false)
  taxExempt        Boolean   @default(false)
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([businessId])
  @@index([businessId, deletedAt])
  @@index([email])
  @@index([phone])
}

// ─── Orders & Payments ───────────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  businessId     String
  locationId     String
  orderNumber    String
  status         OrderStatus @default(DRAFT)
  employeeId     String?
  customerId     String?
  subtotal       Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @default(0) @db.Decimal(10, 2)
  notes          String?
  heldAt         DateTime?
  paidAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location         Location         @relation(fields: [locationId], references: [id])
  employee         EmployeeProfile? @relation(fields: [employeeId], references: [id])
  customer         Customer?        @relation(fields: [customerId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  refunds          Refund[]
  receipts         Receipt[]
  appliedDiscounts OrderDiscount[]

  @@unique([businessId, orderNumber])
  @@index([businessId])
  @@index([businessId, paidAt])
  @@index([businessId, status, createdAt])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String?
  variantId      String?
  name           String
  sku            String?
  quantity       Int      @default(1)
  unitPrice      Decimal  @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(10, 2)
  modifiers      Json?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  refundItems RefundItem[]

  @@index([orderId])
}

model Payment {
  id                    String        @id @default(cuid())
  businessId            String
  orderId               String
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  amountTendered        Decimal?      @db.Decimal(10, 2)
  changeDue             Decimal?      @db.Decimal(10, 2)
  stripePaymentIntentId String?
  stripeChargeId        String?
  cardLast4             String?
  cardBrand             String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([orderId])
  @@index([stripePaymentIntentId])
}

model Refund {
  id             String       @id @default(cuid())
  businessId     String
  orderId        String
  employeeId     String?
  amount         Decimal      @db.Decimal(10, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(10, 2)
  reason         RefundReason
  reasonNote     String?
  stripeRefundId String?
  returnToStock  Boolean      @default(false)
  createdAt      DateTime     @default(now())

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  employee EmployeeProfile? @relation(fields: [employeeId], references: [id])
  items    RefundItem[]
  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([orderId])
}

model RefundItem {
  id          String  @id @default(cuid())
  refundId    String
  orderItemId String
  quantity    Int
  amount      Decimal @db.Decimal(10, 2)

  refund    Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}

model Discount {
  id               String       @id @default(cuid())
  businessId       String
  name             String
  code             String?
  type             DiscountType
  value            Decimal      @db.Decimal(10, 2)
  minCartAmount    Decimal?     @db.Decimal(10, 2)
  usageLimit       Int?
  usageCount       Int          @default(0)
  startDate        DateTime?
  endDate          DateTime?
  requiresApproval Boolean      @default(false)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderDiscounts OrderDiscount[]

  @@index([businessId])
  @@index([code])
}

model OrderDiscount {
  id         String       @id @default(cuid())
  orderId    String
  discountId String?
  name       String
  type       DiscountType
  value      Decimal      @db.Decimal(10, 2)
  amount     Decimal      @db.Decimal(10, 2)

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount Discount? @relation(fields: [discountId], references: [id])
}

model TaxRate {
  id                String   @id @default(cuid())
  businessId        String
  locationId        String?
  name              String
  rate              Decimal  @db.Decimal(5, 4)
  appliesToProducts Boolean  @default(true)
  appliesToServices Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])

  @@index([businessId])
  @@index([locationId])
}

model Receipt {
  id            String    @id @default(cuid())
  businessId    String
  orderId       String
  receiptNumber String
  emailedTo     String?
  lastEmailedAt DateTime?
  printed       Boolean   @default(false)
  printedAt     DateTime?
  createdAt     DateTime  @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([orderId])
}

// ─── Cash Drawer ─────────────────────────────────────────────────────────────

model RegisterSession {
  id           String                @id @default(cuid())
  businessId   String
  locationId   String
  employeeId   String
  status       RegisterSessionStatus @default(OPEN)
  openingCash  Decimal               @default(0) @db.Decimal(10, 2)
  cashSales    Decimal               @default(0) @db.Decimal(10, 2)
  cashRefunds  Decimal               @default(0) @db.Decimal(10, 2)
  paidIn       Decimal               @default(0) @db.Decimal(10, 2)
  paidOut      Decimal               @default(0) @db.Decimal(10, 2)
  expectedCash Decimal?              @db.Decimal(10, 2)
  actualCash   Decimal?              @db.Decimal(10, 2)
  overShort    Decimal?              @db.Decimal(10, 2)
  openedAt     DateTime              @default(now())
  closedAt     DateTime?

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location      Location        @relation(fields: [locationId], references: [id])
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id])
  cashMovements CashMovement[]

  @@index([businessId])
  @@index([locationId])
}

model CashMovement {
  id                String           @id @default(cuid())
  registerSessionId String
  type              CashMovementType
  amount            Decimal          @db.Decimal(10, 2)
  reason            String?
  createdAt         DateTime         @default(now())

  registerSession RegisterSession @relation(fields: [registerSessionId], references: [id], onDelete: Cascade)
}

// ─── Stripe ──────────────────────────────────────────────────────────────────

model StripeAccount {
  id               String              @id @default(cuid())
  businessId       String              @unique
  stripeAccountId  String?             @unique
  status           StripeAccountStatus @default(NOT_CONNECTED)
  chargesEnabled   Boolean             @default(false)
  payoutsEnabled   Boolean             @default(false)
  detailsSubmitted Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model TerminalReader {
  id             String       @id @default(cuid())
  businessId     String
  locationId     String?
  stripeReaderId String?
  name           String
  serialNumber   String?
  status         ReaderStatus @default(OFFLINE)
  isDefault      Boolean      @default(false)
  lastActiveAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([locationId])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// ─── Settings & Audit ────────────────────────────────────────────────────────

model BusinessSetting {
  id                          String   @id @default(cuid())
  businessId                  String   @unique
  enableCash                  Boolean  @default(true)
  enableCard                  Boolean  @default(true)
  enableManualDiscount        Boolean  @default(true)
  requireCustomer             Boolean  @default(false)
  requireManagerRefund        Boolean  @default(true)
  allowCustomItems            Boolean  @default(true)
  requirePinAtRegister        Boolean  @default(false)
  requireManagerPinRefund     Boolean  @default(true)
  managerPinDiscountThreshold Decimal? @db.Decimal(5, 2)
  sessionTimeoutMinutes       Int      @default(30)
  receiptFooter               String?
  returnPolicy                String?
  showCashierOnReceipt        Boolean  @default(true)
  showCustomerOnReceipt       Boolean  @default(true)
  showBusinessEmailOnReceipt  Boolean  @default(true)
  showBusinessPhoneOnReceipt  Boolean  @default(true)
  showSkuOnReceipt            Boolean  @default(false)
  enableBarcodeScanning       Boolean  @default(true)
  enableReceiptPrinting       Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ModuleSetting {
  id         String   @id @default(cuid())
  businessId String
  module     String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, module])
  @@index([businessId])
}

model AuditLog {
  id         String      @id @default(cuid())
  businessId String
  employeeId String?
  action     AuditAction
  entity     String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee EmployeeProfile? @relation(fields: [employeeId], references: [id])

  @@index([businessId])
  @@index([createdAt])
  @@index([entity])
}

// ─── Workforce ───────────────────────────────────────────────────────────────

model WorkforceSettings {
  id                     String        @id @default(cuid())
  businessId             String        @unique
  payPeriodType          PayPeriodType @default(BIWEEKLY)
  weekStartDay           Int           @default(0)
  overtimeThresholdHours Decimal       @default(40) @db.Decimal(6, 2)
  defaultPtoAnnualHours  Decimal       @default(80) @db.Decimal(8, 2)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Shift {
  id          String      @id @default(cuid())
  businessId  String
  employeeId  String
  locationId  String?
  startAt     DateTime
  endAt       DateTime
  notes       String?
  status      ShiftStatus @default(SCHEDULED)
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location    Location?       @relation(fields: [locationId], references: [id])
  createdBy   EmployeeProfile @relation("ShiftCreatedBy", fields: [createdById], references: [id])
  timeEntries TimeEntry[]

  @@index([businessId])
  @@index([employeeId])
  @@index([startAt])
}

model TimeEntry {
  id             String          @id @default(cuid())
  businessId     String
  employeeId     String
  locationId     String?
  shiftId        String?
  clockIn        DateTime
  clockOut       DateTime?
  source         TimeEntrySource @default(PIN_KIOSK)
  status         TimeEntryStatus @default(ACTIVE)
  adjustedById   String?
  adjustmentNote String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location   Location?        @relation(fields: [locationId], references: [id])
  shift      Shift?           @relation(fields: [shiftId], references: [id])
  adjustedBy EmployeeProfile? @relation("TimeEntryAdjustedBy", fields: [adjustedById], references: [id])
  breaks     TimeBreak[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([employeeId])
  @@index([clockIn])
  @@index([status])
}

model TimeBreak {
  id          String    @id @default(cuid())
  timeEntryId String
  breakStart  DateTime
  breakEnd    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  timeEntry TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([timeEntryId])
}

model TimeOffRequest {
  id             String        @id @default(cuid())
  businessId     String
  employeeId     String
  startDate      DateTime      @db.Date
  endDate        DateTime      @db.Date
  hoursRequested Decimal       @db.Decimal(8, 2)
  type           TimeOffType   @default(PTO)
  status         TimeOffStatus @default(PENDING)
  notes          String?
  reviewedById   String?
  reviewedAt     DateTime?
  denialReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy EmployeeProfile? @relation("TimeOffReviewedBy", fields: [reviewedById], references: [id])

  @@index([businessId])
  @@index([employeeId])
  @@index([status])
}

model PayrollBonus {
  id             String   @id @default(cuid())
  businessId     String
  employeeId     String
  amount         Decimal  @db.Decimal(10, 2)
  description    String
  payPeriodStart DateTime @db.Date
  payPeriodEnd   DateTime @db.Date
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business  Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee  EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy EmployeeProfile @relation("PayrollBonusCreatedBy", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([employeeId])
  @@index([payPeriodStart, payPeriodEnd])
}

// ─── Expense Management ──────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
  REIMBURSED
  PAID
  ARCHIVED
}

enum ExpensePaymentMethod {
  COMPANY_CARD
  PERSONAL_CARD
  CASH
  BANK_TRANSFER
  OTHER
}

enum CompanyCardType {
  CREDIT
  DEBIT
  VIRTUAL
  CHARGE
}

enum CompanyCardStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum ExpenseFlagType {
  DUPLICATE
  LARGE_PURCHASE
  WEEKEND
  AFTER_HOURS
  WRONG_CATEGORY
  SPLIT_TRANSACTION
  REPEATED_IDENTICAL
  OUT_OF_POLICY
  MISSING_RECEIPT
  MANUAL
}

enum ExpenseFlagSeverity {
  INFO
  WARNING
  HIGH
}

enum ExpenseNotificationType {
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  RECEIPT_MISSING
  MANAGER_COMMENTED
  BUDGET_EXCEEDED
  PENDING_APPROVAL
  LARGE_PURCHASE
  SUSPICIOUS_PURCHASE
  REQUEST_CHANGES
  REIMBURSEMENT_PAID
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum CardTransactionSource {
  MANUAL
  STRIPE
  AMEX
  CHASE
  CAPITAL_ONE
  BREX
  RAMP
  PLAID
  OTHER
}

enum ExpenseReceiptKind {
  IMAGE
  PDF
}

model ExpenseSettings {
  id                      String   @id @default(cuid())
  businessId              String   @unique
  largePurchaseThreshold  Decimal  @default(500) @db.Decimal(12, 2)
  requireReceiptAbove     Decimal  @default(25) @db.Decimal(12, 2)
  afterHoursStart         Int      @default(20)
  afterHoursEnd           Int      @default(6)
  weekendFlagsEnabled     Boolean  @default(true)
  autoSubmitOnCreate      Boolean  @default(false)
  defaultCurrency         String   @default("USD")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  slug        String
  description String?
  isSystem    Boolean   @default(false)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  business       Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  budgets        ExpenseBudget[]
  vendors        ExpenseVendor[]
  allowedOnCards CompanyCardAllowedCategory[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, isActive])
}

model ExpenseVendor {
  id           String    @id @default(cuid())
  businessId   String
  name         String
  normalizedName String
  categoryId   String?
  address      String?
  phone        String?
  website      String?
  notes        String?
  isFavorite   Boolean   @default(false)
  purchaseCount Int      @default(0)
  totalSpend   Decimal   @default(0) @db.Decimal(14, 2)
  averageSpend Decimal   @default(0) @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  expenses Expense[]

  @@unique([businessId, normalizedName])
  @@index([businessId])
  @@index([businessId, name])
}

model CompanyCard {
  id                 String            @id @default(cuid())
  businessId         String
  name               String
  lastFour           String
  bank               String?
  cardType           CompanyCardType   @default(CREDIT)
  assignedEmployeeId String?
  monthlyLimit       Decimal?          @db.Decimal(12, 2)
  dailyLimit         Decimal?          @db.Decimal(12, 2)
  status             CompanyCardStatus @default(ACTIVE)
  notes              String?
  /// Future sync provider key (stripe, amex, plaid, etc.)
  syncProvider       String?
  syncExternalId     String?
  createdById        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  business         Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedEmployee EmployeeProfile?              @relation("CompanyCardAssignee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  createdBy        EmployeeProfile?              @relation("CompanyCardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  allowedCategories CompanyCardAllowedCategory[]
  expenses         Expense[]
  transactions     CompanyCardTransaction[]

  @@index([businessId])
  @@index([businessId, lastFour])
  @@index([assignedEmployeeId])
  @@index([status])
}

model CompanyCardAllowedCategory {
  id         String @id @default(cuid())
  cardId     String
  categoryId String

  card     CompanyCard     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([cardId, categoryId])
}

/// Abstraction layer for card feeds (manual today; Stripe/Amex/Plaid later).
model CompanyCardTransaction {
  id              String                @id @default(cuid())
  businessId      String
  companyCardId   String?
  employeeId      String?
  source          CardTransactionSource @default(MANUAL)
  externalId      String?
  merchantName    String
  amount          Decimal               @db.Decimal(12, 2)
  currency        String                @default("USD")
  purchasedAt     DateTime
  rawPayload      Json?
  matchedExpenseId String?              @unique
  postedAt        DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  companyCard  CompanyCard?     @relation(fields: [companyCardId], references: [id], onDelete: SetNull)
  employee     EmployeeProfile? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  matchedExpense Expense?       @relation(fields: [matchedExpenseId], references: [id], onDelete: SetNull)

  @@unique([businessId, source, externalId])
  @@index([businessId])
  @@index([companyCardId])
  @@index([purchasedAt])
}

model Expense {
  id                 String               @id @default(cuid())
  businessId         String
  employeeId         String
  submittedById      String?
  categoryId         String?
  vendorId           String?
  companyCardId      String?
  locationId         String?
  department         String?
  project            String?
  jobNumber          String?
  merchant           String
  amount             Decimal              @db.Decimal(12, 2)
  tax                Decimal              @default(0) @db.Decimal(12, 2)
  tip                Decimal              @default(0) @db.Decimal(12, 2)
  total              Decimal              @db.Decimal(12, 2)
  currency           String               @default("USD")
  purchaseDate       DateTime             @db.Date
  paymentMethod      ExpensePaymentMethod @default(COMPANY_CARD)
  mileageMiles       Decimal?             @db.Decimal(10, 2)
  mileageRate        Decimal?             @db.Decimal(8, 4)
  notes              String?
  status             ExpenseStatus        @default(DRAFT)
  missingReceipt     Boolean              @default(false)
  receiptReminderAt  DateTime?
  reimbursedAt       DateTime?
  reimbursedAmount   Decimal?             @db.Decimal(12, 2)
  paidAt             DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  submittedAt        DateTime?
  archivedAt         DateTime?
  contentHash        String?
  ocrRawText         String?
  ocrConfidence      Decimal?             @db.Decimal(5, 2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  business         Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee         EmployeeProfile         @relation("ExpenseEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  submittedBy      EmployeeProfile?        @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  category         ExpenseCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  vendor           ExpenseVendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  companyCard      CompanyCard?            @relation(fields: [companyCardId], references: [id], onDelete: SetNull)
  location         Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  receipts         ExpenseReceipt[]
  lineItems        ExpenseLineItem[]
  tags             ExpenseTagAssignment[]
  comments         ExpenseComment[]
  approvalEvents   ExpenseApprovalEvent[]
  flags            ExpenseFlag[]
  matchedTransaction CompanyCardTransaction?

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, purchaseDate])
  @@index([employeeId])
  @@index([categoryId])
  @@index([vendorId])
  @@index([companyCardId])
  @@index([locationId])
  @@index([merchant])
  @@index([total])
  @@index([contentHash])
  @@index([deletedAt])
}

model ExpenseReceipt {
  id            String             @id @default(cuid())
  expenseId     String
  kind          ExpenseReceiptKind @default(IMAGE)
  fileName      String
  mimeType      String
  sizeBytes     Int
  /// Data URL or storage URL — never store full PAN/card numbers from OCR into notes alone.
  storageUrl    String
  pageNumber    Int                @default(1)
  width         Int?
  height        Int?
  contentHash   String?
  ocrText       String?
  enhanced      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([contentHash])
}

model ExpenseLineItem {
  id          String   @id @default(cuid())
  expenseId   String
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model ExpenseTag {
  id         String   @id @default(cuid())
  businessId String
  name       String
  color      String?  @default("#64748b")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business    Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignments ExpenseTagAssignment[]

  @@unique([businessId, name])
  @@index([businessId])
}

model ExpenseTagAssignment {
  id        String @id @default(cuid())
  expenseId String
  tagId     String

  expense Expense    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  tag     ExpenseTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([expenseId, tagId])
}

model ExpenseComment {
  id         String   @id @default(cuid())
  expenseId  String
  authorId   String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  expense Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  author  EmployeeProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model ExpenseApprovalEvent {
  id         String        @id @default(cuid())
  expenseId  String
  actorId    String
  fromStatus ExpenseStatus?
  toStatus   ExpenseStatus
  action     String
  note       String?
  createdAt  DateTime      @default(now())

  expense Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  actor   EmployeeProfile @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([createdAt])
}

model ExpenseFlag {
  id          String              @id @default(cuid())
  expenseId   String
  type        ExpenseFlagType
  severity    ExpenseFlagSeverity @default(WARNING)
  message     String
  resolved    Boolean             @default(false)
  raisedById  String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  expense  Expense          @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  raisedBy EmployeeProfile? @relation(fields: [raisedById], references: [id], onDelete: SetNull)

  @@index([expenseId])
  @@index([type])
}

model ExpenseBudget {
  id         String       @id @default(cuid())
  businessId String
  categoryId String
  period     BudgetPeriod
  amount     Decimal      @db.Decimal(14, 2)
  year       Int
  month      Int?
  quarter    Int?
  alert75    Boolean      @default(true)
  alert90    Boolean      @default(true)
  alert100   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([businessId, categoryId, period, year, month, quarter])
  @@index([businessId])
  @@index([categoryId])
}

model ExpenseNotification {
  id         String                  @id @default(cuid())
  businessId String
  employeeId String
  type       ExpenseNotificationType
  title      String
  body       String
  expenseId  String?
  href       String?
  readAt     DateTime?
  createdAt  DateTime                @default(now())

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([employeeId, readAt])
  @@index([createdAt])
}

/// Immutable expense-domain audit trail with before/after snapshots.
model ExpenseAuditEvent {
  id         String   @id @default(cuid())
  businessId String
  actorId    String?
  expenseId  String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor    EmployeeProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([expenseId])
  @@index([createdAt])
  @@index([entity])
}

model ExpenseSavedFilter {
  id         String   @id @default(cuid())
  businessId String
  employeeId String
  name       String
  filters    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, name])
  @@index([businessId])
}
